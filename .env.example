# Copy this file to .env and fill in real values.

# --- Database ---
# Local dev (SQLite):
DATABASE_URL="file:./dev.db"
# Production (PostgreSQL example):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# --- Site ---
# Public base URL (no trailing slash). Used for SEO sitemap/robots/OpenGraph.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# WhatsApp "Chat with us" number, international format, digits only (e.g. 919487789546)
NEXT_PUBLIC_WHATSAPP_NUMBER="919487789546"

# --- Auth ---
# REQUIRED. Use a long random string (min 32 chars). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=""

# --- Payments: Razorpay ---
# Leave blank to use the built-in mock payment (dev/demo only).
# Get free TEST keys at https://dashboard.razorpay.com (Settings > API Keys).
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# Must equal RAZORPAY_KEY_ID; exposed to the browser checkout widget.
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# --- Seeded admin account (used by `npm run db:seed`) ---
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-strong-password"
